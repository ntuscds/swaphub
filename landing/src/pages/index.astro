    <script is:inline>
      const mouseGlow = document.getElementById("mouse-glow");

      if (mouseGlow) {
        window.addEventListener("mousemove", (event) => {
          mouseGlow.style.background = `radial-gradient(600px at ${event.clientX}px ${event.clientY}px, rgba(99,102,241,0.12), transparent 80%)`;
        });
      }

      (() => {
        const xlQuery = window.matchMedia("(min-width: 1280px)");
        const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

        const initEllipsePlaneAnimation = ({
          containerId,
          planeId,
          startAngle,
          endAngle,
          getEllipse,
          scrollMultiplier = 0.35,
          scaleMultiplier = 3,
          scrollMode = "top",
          scaleIn = false,
        }) => {
          const container = document.getElementById(containerId);
          const plane = document.getElementById(planeId);
          if (!container || !plane) return;

          const angleRange = Math.abs(endAngle - startAngle);
          const angleStep = endAngle >= startAngle ? 1 : -1;
          let initialTop = null;

          const getScrollPx = () => {
            if (scrollMode === "page-bottom") {
              const animationScrollDistance = angleRange / scrollMultiplier;
              const pixelsFromPageBottom =
                document.documentElement.scrollHeight -
                window.scrollY -
                window.innerHeight;
              return clamp(
                (animationScrollDistance - pixelsFromPageBottom) *
                  scrollMultiplier,
                0,
                angleRange
              );
            }

            const rect = container.getBoundingClientRect();
            const rawOffset =
              scrollMode === "bottom"
                ? initialTop - rect.bottom
                : initialTop - rect.top;
            return clamp(rawOffset * scrollMultiplier, 0, angleRange);
          };

          const resetInitialAnchor = () => {
            if (scrollMode === "page-bottom") return;

            const rect = container.getBoundingClientRect();
            const rawOffset = initialTop === null ? 0 : initialTop - rect.top;
            const currentScrollPx = clamp(
              rawOffset * scrollMultiplier,
              0,
              angleRange
            );
            initialTop = rect.top + currentScrollPx / scrollMultiplier;
          };

          const updatePlane = () => {
            if (!xlQuery.matches) return;

            const rect = container.getBoundingClientRect();
            const { width, height } = rect;
            if (scrollMode !== "page-bottom" && initialTop === null) {
              resetInitialAnchor();
            }

            const scrollPx = getScrollPx();
            const x = scrollPx / angleRange;
            const angleDeg = startAngle + angleStep * scrollPx;

            const scaleFactor = scaleIn
              ? clamp(Math.sqrt(x), 0, 1)
              : clamp(1 - Math.sqrt(x), 0, 1);
            const scale = scaleFactor * scaleMultiplier;
            const opacity = clamp(1 - 0.5 * x, 0, 1);

            const { cx, cy, rx, ry } = getEllipse(width, height);
            const rad = (angleDeg * Math.PI) / 180;

            const px = cx + rx * Math.cos(rad);
            const py = cy + ry * Math.sin(rad);
            const rotation =
              (Math.atan2(ry * Math.cos(rad), -rx * Math.sin(rad)) * 180) /
              Math.PI;

            plane.style.left = `${px}px`;
            plane.style.top = `${py}px`;
            plane.style.transform = `translate(-50%, -50%) rotate(${rotation}deg) scale(${scale})`;

            const planeSvg = plane.querySelector("svg");
            if (planeSvg instanceof SVGElement) {
              planeSvg.style.opacity = String(opacity);
            }
          };

          resetInitialAnchor();
          updatePlane();

          window.addEventListener("scroll", updatePlane, { passive: true });
          window.addEventListener("resize", () => {
            resetInitialAnchor();
            updatePlane();
          });
          xlQuery.addEventListener("change", updatePlane);
        };

        initEllipsePlaneAnimation({
          containerId: "hero-section-animation-lg",
          planeId: "hero-plane",
          startAngle: 225,
          endAngle: 315,
          getEllipse: (width, height) => ({
            cx: width / 2,
            cy: height,
            rx: width / 2,
            ry: (height * 2) / 3,
          }),
        });

        initEllipsePlaneAnimation({
          containerId: "bottom-section-animation-lg",
          planeId: "bottom-plane",
          startAngle: 360,
          endAngle: 225,
          scrollMode: "page-bottom",
          scaleIn: true,
          getEllipse: (width, height) => ({
            cx: width,
            cy: height,
            rx: (width * 2) / 3,
            ry: height / 2,
          }),
        });

        const initSmallPlanePathAnimation = ({
          containerId,
          planeConfigs,
          direction = "ltr",
          planeWidth = 98,
          pathDurationMs = 8000,
          rotationOffset = 0,
        }) => {
          const smQuery = window.matchMedia("(max-width: 1279px)");

          const container = document.getElementById(containerId);
          if (!container) return;

          const randomCoeff = () => Math.random() * 2 - 1;

          const createPathParams = () => ({
            a: randomCoeff(),
            b: randomCoeff(),
            c: randomCoeff(),
          });

          const toTheta = (x, width) => (x / width) * (2 * Math.PI);

          const pathY = (x, width, params) => {
            const theta = toTheta(x, width);
            return (
              (1 / 3) * Math.sin(params.a * theta) +
              (1 / 3) * Math.sin(params.b * theta) +
              (1 / 3) * Math.sin(params.c * theta)
            );
          };

          const pathDerivative = (x, width, params) => {
            const theta = toTheta(x, width);
            const dThetaDx = (2 * Math.PI) / width;
            return (
              dThetaDx *
              ((1 / 3) * params.a * Math.cos(params.a * theta) +
                (1 / 3) * params.b * Math.cos(params.b * theta) +
                (1 / 3) * params.c * Math.cos(params.c * theta))
            );
          };

          const applyPlaneTransform = (plane, px, py, rotationDeg) => {
            plane.style.left = `${px}px`;
            plane.style.top = `${py}px`;
            plane.style.transform = `translate(-50%, -50%) rotate(${rotationDeg}deg)`;
          };

          const getPathBounds = (width) => {
            const xStart =
              direction === "ltr" ? -planeWidth : width + planeWidth;
            const xEnd = direction === "ltr" ? width + planeWidth : -planeWidth;
            return { xStart, xEnd, pathWidth: xEnd - xStart };
          };

          const getRotation = (px, width, height, params) => {
            const { pathWidth } = getPathBounds(width);
            const amplitude = height * 0.45;
            const dydx = pathDerivative(px, width, params);
            const dydt = amplitude * dydx * pathWidth;
            return (
              (Math.atan2(dydt, pathWidth) * 180) / Math.PI + rotationOffset
            );
          };

          for (const { id, delayMs } of planeConfigs) {
            const plane = document.getElementById(id);
            if (!plane) continue;

            let state = "delay";
            let pathParams = createPathParams();
            let animStartTime = 0;
            let pauseEndTime = 0;
            let delayEndTime = performance.now() + delayMs;

            const tick = (now) => {
              if (!smQuery.matches) {
                requestAnimationFrame(tick);
                return;
              }

              const { width, height } = container.getBoundingClientRect();
              const midY = height / 2;
              const amplitude = height * 0.45;
              const { xStart, pathWidth } = getPathBounds(width);

              if (state === "delay") {
                if (now < delayEndTime) {
                  applyPlaneTransform(
                    plane,
                    xStart,
                    midY,
                    getRotation(xStart, width, height, pathParams)
                  );
                  requestAnimationFrame(tick);
                  return;
                }
                state = "animate";
                animStartTime = now;
                pathParams = createPathParams();
              }

              if (state === "pause") {
                if (now < pauseEndTime) {
                  requestAnimationFrame(tick);
                  return;
                }
                state = "animate";
                animStartTime = now;
                pathParams = createPathParams();
              }

              const elapsed = now - animStartTime;
              const t = clamp(elapsed / pathDurationMs, 0, 1);
              const px = xStart + t * pathWidth;
              const py = midY + amplitude * pathY(px, width, pathParams);
              const rotation = getRotation(px, width, height, pathParams);

              applyPlaneTransform(plane, px, py, rotation);

              if (t >= 1) {
                state = "pause";
                pauseEndTime = now + Math.random() * 1000;
              }

              requestAnimationFrame(tick);
            };

            requestAnimationFrame(tick);
          }
        };

        initSmallPlanePathAnimation({
          containerId: "hero-section-animation-sm",
          planeConfigs: [
            { id: "hero-plane-sm-1", delayMs: 0 },
            { id: "hero-plane-sm-2", delayMs: 2000 },
          ],
          direction: "ltr",
          planeWidth: 98,
        });

        initSmallPlanePathAnimation({
          containerId: "cta-section-animation-sm",
          planeConfigs: [
            { id: "cta-plane-sm-1", delayMs: 0 },
            { id: "cta-plane-sm-2", delayMs: 2000 },
          ],
          direction: "rtl",
          planeWidth: 97,
          rotationOffset: 180,
        });
      })();
    </script>
