---
import Image from "astro/components/Image.astro";
import Posthog from "../components/posthog.astro";
import { Chat } from "../components/chat";
import "../styles/global.css";
import HeroImage from "@/../public/signup-dark.png";
import Step1Image from "@/../public/see-1.png";
import Step2Image from "@/../public/see-2.png";
import Step3Image from "@/../public/see-3.png";

const SIGNIN_URL = `${import.meta.env.MAIN_APP_URL}/api/auth/microsoft/login?callbackUrl=${encodeURIComponent("/onboard")}`;

const NAMES = [
  "Monkey",
  "ICC Lover",
  "CC is my passion",
  "Disgruntled Student",
  "Minmaxer3000",
  "Trillionaire",
  "Please hire me",
  "Sleep Deprived",
  "Procrastinator",
  "Exchange Kid",
  "CC Lover",
  "I really need a job",
  "Hire me",
  "Stop ghosting my apps",
  "GPA Gambler",
  "Covfefe",
];

const COURSES = [
  "ML4",
  "CC6",
  "CC7",
  "CC2",
  "CC3",
  "CC15",
  "ML0004",
  "CC0006",
  "CC0007",
  "CC0003",
  "CC0002",
  "CC0015",
  "SC3000",
  "SC2207",
  "SC1006",
  "MH1812",
  "SC1004",
  "AB1501",
  "AB1301",
  "DM3015",
  "MA4002",
];

const DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri"];

const TEAM = [
  {
    name: "Benedict Tan",
    photo: "/benedict.jpg",
    linkedin: "https://www.linkedin.com/in/benedict-tan-265403215/",
  },
  {
    name: "Vidisha Bajoria",
    photo: "/vidisha.jpg",
    linkedin: "https://www.linkedin.com/in/vidishabajoria/",
  },
  {
    name: "Suhani Mishra",
    photo: "/suhani.jpg",
    linkedin: "https://www.linkedin.com/in/suhanimishra07/",
  },
  {
    name: "Rushika Gupta",
    photo: "/rushika.jpg",
    linkedin: "https://www.linkedin.com/in/rushikagupta/",
  },
  {
    name: "Shrujan Beesetty",
    photo: "/shrujan.jpg",
    linkedin: "https://www.linkedin.com/in/shrujan-beesetty/",
  },
];
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>SwapHub</title>
    <meta name="description" content="Stop Wasting Time, Use SwapHub!" />
    <meta name="application-name" content="SwapHub" />
    <meta name="author" content="SwapHub" />
    <meta
      name="keywords"
      content="Swap, Hub, ntu, index swapping, course planning"
    />

    <!-- Open Graph -->
    <meta property="og:title" content="SwapHub — Swap Your Indexes Instantly" />
    <meta property="og:description" content="Stop Wasting Time, Use SwapHub!" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content="https://swaphub.ntuscds.com" />
    <meta property="og:image" content="/banner.png" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="600" />
    <meta property="og:image:alt" content="SwapHub thumbnail" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@acrylic125" />
    <meta name="twitter:creator" content="@acrylic125" />
    <meta name="twitter:title" content="SwapHub" />
    <meta
      name="twitter:description"
      content="Stop Wasting Time, Use SwapHub!"
    />
    <meta name="twitter:image" content="/banner.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <Posthog />
  </head>
  <body
    class="relative flex flex-col items-center overflow-x-hidden bg-background text-foreground"
  >
    <div
      id="mouse-glow"
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-20 transition-all duration-300"
      style="background: radial-gradient(600px at 50% 50%, rgba(99,102,241,0.12), transparent 100%);"
    >
    </div>
    <main class="relative z-10 flex flex-col gap-12 items-center w-full">
      <div class="relative w-full flex flex-row max-w-ui">
        <div
          id="hero-section-animation-sm"
          class="absolute top-1/7 left-0 w-full h-3/7 xl:hidden overflow-hidden pointer-events-none"
        >
          <div id="hero-plane-sm-1" class="absolute will-change-transform">
            <svg
              width="98"
              height="56"
              viewBox="0 0 196 112"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M56.5963 55.5207L23.2302 0L193.842 55.5207L0 110.079L56.5963 55.5207Z"
                fill="#1E3B8A"></path>
              <path
                d="M0 110.079L54.774 55.5205H194.87L0 110.079Z"
                fill="#172554"></path>
              <path
                d="M25.7441 65.8602L55.5292 57.1194L25.7443 45.2935L25.7441 65.8602Z"
                fill="#172554"></path>
            </svg>
          </div>
          <div
            id="hero-plane-sm-2"
            class="absolute overflow-hidden will-change-transform"
          >
            <svg
              width="98"
              height="56"
              viewBox="0 0 196 112"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M56.5963 55.5207L23.2302 0L193.842 55.5207L0 110.079L56.5963 55.5207Z"
                fill="#1E3B8A"></path>
              <path
                d="M0 110.079L54.774 55.5205H194.87L0 110.079Z"
                fill="#172554"></path>
              <path
                d="M25.7441 65.8602L55.5292 57.1194L25.7443 45.2935L25.7441 65.8602Z"
                fill="#172554"></path>
            </svg>
          </div>
        </div>
        <div
          class="absolute top-0 left-0 w-full h-full hidden xl:block overflow-visible pointer-events-none"
          id="hero-section-animation-lg"
        >
          <!-- Plane -->
          <div id="hero-plane" class="absolute will-change-transform">
            <svg
              width="196"
              height="112"
              viewBox="0 0 196 112"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M56.5963 55.5207L23.2302 0L193.842 55.5207L0 110.079L56.5963 55.5207Z"
                fill="#1E3B8A"></path>
              <path
                d="M0 110.079L54.774 55.5205H194.87L0 110.079Z"
                fill="#172554"></path>
              <path
                d="M25.7441 65.8602L55.5292 57.1194L25.7443 45.2935L25.7441 65.8602Z"
                fill="#172554"></path>
            </svg>
          </div>
        </div>
        <!-- Header area -->
        <div
          class="w-full flex flex-col xl:flex-row max-w-ui items-center z-10"
        >
          <div
            class="flex-2 flex flex-col gap-4 md:gap-6 lg:gap-8 py-20 md:py-24 lg:py-28 px-8 md:px-12 lg:px-16"
          >
            <div class="w-full flex flex-col gap-4">
              <h1
                class="text-center xl:text-left hero-title font-black text-5xl md:text-6xl lg:text-7xl xl:text-7xl leading-14 sm:leading-16 md:leading-18 lg:leading-20"
              >
                Swap Your<br />Indexes<br />Instantly.
              </h1>
            </div>

            <div
              class="flex flex-col lg:flex-row gap-2 items-center lg:items-start"
            >
              <a
                href="https://t.me/swaphub_ntu_bot/app"
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-md w-fit px-4 py-2.5 h-fit flex flex-row gap-2 lg:gap-2.5 items-center bg-sky-600 text-white transition-colors"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
                  ></path>
                </svg>
                Open in Telegram
              </a>
              <a
                href="https://app.swaphub.ntuscds.com/"
                class="rounded-md w-fit px-4 py-2.5 h-fit flex flex-row gap-1 lg:gap-2.5 items-center bg-background-300 dark:bg-background-800 text-foreground"
              >
                Continue on Web
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-arrow-right-icon lucide-arrow-right"
                  ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                  ></path></svg
                >
              </a>
            </div>
          </div>
          <div class="flex-2 lg:flex-3 h-full px-8">
            <Image src={HeroImage} alt="SwapHub Hero" layout="full-width" />
          </div>
        </div>
      </div>

      <section
        class="w-full flex flex-col gap-8 items-center max-w-ui py-12 px-4 sm:px-6 md:px-8 lg:px-16"
      >
        <header class="flex flex-col items-center lg:gap-2">
          <span
            class="text-primary-500 font-semibold text-xs md:text-sm lg:text-base xl:text-lg uppercase text-center"
          >
            The Problem
          </span>
          <h2
            class="text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold text-center leading-10 md:leading-12 lg:leading-14"
          >
            We felt the <span class="hero-title">Pain</span>
          </h2>
        </header>
        <Chat client:only="react" names={NAMES} courses={COURSES} days={DAYS} />
      </section>

      <section class="relative w-full flex flex-row max-w-ui">
        <div class="w-full relative">
          <!-- Step 1 -->
          <div class="sticky top-0 h-svh w-full">
            <div class="bg-background">
              <div
                class="w-full max-w-ui h-screen overflow-y-hidden flex not-landscape:flex-col landscape:flex-row"
              >
                <div
                  class="not-landscape:h-fit landscape:flex-1 flex flex-col gap-4 py-8 md:py-12 lg:py-16 xl:py-20 2xl:py-24 px-8 md:px-12 lg:px-16"
                >
                  <div class="flex flex-col gap-1 lg:gap-2">
                    <span
                      class="text-primary-500 font-semibold text-xs md:text-sm uppercase"
                    >
                      See It In Action
                    </span>
                    <h2
                      class="text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold leading-8 md:leading-10 xl:leading-12"
                    >
                      How SwapHub changes everything!
                    </h2>
                  </div>
                  <div class="flex flex-row gap-4 flex-1 items-center">
                    <div class="flex flex-row gap-4">
                      <div
                        class="w-6 h-6 md:w-8 md:h-8 lg:w-10 lg:h-10 flex flex-col items-center justify-center gap-4 bg-primary-700 text-foreground rounded-md lg:rounded-lg text-sm md:text-base lg:text-lg"
                      >
                        1
                      </div>
                      <div class="flex-1 flex flex-col gap-1 lg:gap-2">
                        <h3
                          class="text-sm md:text-base lg:text-lg xl:text-xl text-primary-500 font-medium"
                        >
                          Register your Swap Request
                        </h3>
                        <span
                          class="text-sm md:text-base lg:text-lg xl:text-xl text-foreground landscape:max-w-48 md:landscape:max-w-sm lg:landscape:max-w-md"
                        >
                          Choose a course, select the index you have and the
                          indexes you want
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
                <div
                  class="flex-1 lg:flex-2 flex flex-col items-center justify-center px-4 not-landscape:pb-12"
                >
                  <Image
                    src={Step1Image}
                    alt="Step 1"
                    width={Step1Image.width}
                    height={Step1Image.height}
                    layout="full-width"
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="sticky top-0 h-svh w-full">
            <div class="bg-background">
              <div
                class="w-full max-w-ui h-screen overflow-y-hidden flex not-landscape:flex-col landscape:flex-row"
              >
                <div
                  class="not-landscape:h-fit landscape:flex-1 flex flex-col gap-8 py-8 md:py-12 lg:py-16 xl:py-20 2xl:py-24 px-8 md:px-12 lg:px-16"
                >
                  <div class="flex flex-row gap-4 flex-1 items-center pt-12">
                    <div class="flex flex-row gap-4">
                      <div
                        class="w-6 h-6 md:w-8 md:h-8 lg:w-10 lg:h-10 flex flex-col items-center justify-center gap-4 bg-primary-700 text-foreground rounded-md lg:rounded-lg text-sm md:text-base lg:text-lg"
                      >
                        2
                      </div>
                      <div class="flex-1 flex flex-col gap-2">
                        <h3
                          class="text-sm md:text-base lg:text-lg xl:text-xl text-primary-500 font-medium"
                        >
                          We find your Match
                        </h3>
                        <span
                          class="text-sm md:text-base lg:text-lg xl:text-xl text-foreground landscape:max-w-48 md:landscape:max-w-sm lg:landscape:max-w-md"
                        >
                          See the matches that has the index you want and send a
                          Swap Request to the other party. They will be notified
                          of your Swap Request on Telegram.
                          <br />
                          <br />
                          Likewise, others can be matched to you, and can send you
                          Swap Requests.
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
                <div
                  class="flex-1 lg:flex-2 flex flex-col items-center justify-center px-4 not-landscape:pb-12"
                >
                  <Image
                    src={Step2Image}
                    alt="Step 2"
                    width={Step2Image.width}
                    height={Step2Image.height}
                    layout="full-width"
                  />
                </div>
              </div>
            </div>
          </div>
          <div class="sticky top-0 h-svh w-full">
            <!-- Step 3 -->
            <div class="bg-background">
              <div
                class="w-full max-w-ui h-screen overflow-y-hidden flex not-landscape:flex-col landscape:flex-row"
              >
                <div
                  class="not-landscape:h-fit landscape:flex-1 flex flex-col gap-8 py-10 md:py-12 lg:py-16 xl:py-20 2xl:py-24 px-8 md:px-12 lg:px-16"
                >
                  <div class="flex flex-row gap-4 flex-1 items-center pt-12">
                    <div class="flex flex-row gap-2 md:gap-4">
                      <div
                        class="w-6 h-6 md:w-8 md:h-8 lg:w-10 lg:h-10 flex flex-col items-center justify-center gap-4 bg-primary-700 text-foreground rounded-md lg:rounded-lg text-sm md:text-base lg:text-lg"
                      >
                        3
                      </div>
                      <div class="flex-1 flex flex-col gap-2">
                        <h3
                          class="text-sm md:text-base lg:text-lg xl:text-xl text-primary-500 font-medium"
                        >
                          Complete your Swap
                        </h3>
                        <span
                          class="text-sm md:text-base lg:text-lg xl:text-xl text-foreground landscape:max-w-48 md:landscape:max-w-sm lg:landscape:max-w-md"
                        >
                          Once all parties have accepted the Swap Request, you
                          will receive the other party&apos;s Telegram to liase,
                          and complete the Swap on NTU STARS.
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
                <div
                  class="flex-1 lg:flex-2 flex flex-col items-center justify-center px-4 not-landscape:pb-12"
                >
                  <Image
                    src={Step3Image}
                    alt="Step 3"
                    width={Step3Image.width}
                    height={Step3Image.height}
                    layout="full-width"
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom -->
          <section class="bg-background sticky w-full flex flex-col">
            <div class="relative w-full flex flex-col">
              <div
                class="absolute top-0 left-0 w-full h-full hidden xl:block overflow-visible pointer-events-none"
                id="bottom-section-animation-lg"
              >
                <div id="bottom-plane" class="absolute will-change-transform">
                  <svg
                    width="193"
                    height="110"
                    viewBox="0 0 193 110"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M136.537 54.7458L169.438 0L1.20723 54.7458L192.344 108.542L136.537 54.7458Z"
                      fill="#861336"></path>
                    <path
                      d="M192.344 108.542L138.334 54.7451H0.193497L192.344 108.542Z"
                      fill="#4D0519"></path>
                    <path
                      d="M166.958 64.9408L137.589 56.322L166.958 44.6611L166.958 64.9408Z"
                      fill="#4D0519"></path>
                  </svg>
                </div>
              </div>
              <section
                class="w-full flex flex-col gap-8 items-center py-16 md:py-20 lg:py-24 px-8 md:px-12 lg:px-16 z-10"
              >
                <header class="flex flex-col items-center gap-1 lg:gap-2">
                  <span
                    class="text-primary-500 font-semibold text-xs md:text-sm lg:text-base xl:text-lg uppercase text-center"
                  >
                    The Team
                  </span>
                  <h2
                    class="text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold text-center leading-10 md:leading-12 lg:leading-14"
                  >
                    Meet the Team
                  </h2>
                </header>
                <div
                  class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4"
                >
                  {
                    TEAM.map((member) => (
                      <a
                        href={member.linkedin}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="bg-card border border-border rounded-2xl p-4 flex flex-col items-center text-center gap-3"
                        style={{ textDecoration: "none", color: "inherit" }}
                      >
                        <img
                          src={member.photo}
                          alt={member.name}
                          class="h-14 w-14 rounded-full object-cover transition-all duration-200"
                          style="border: 2px solid rgba(99,102,241,0.3)"
                        />
                        <div class="w-full flex flex-col items-center">
                          <p class="font-medium text-sm lg:text-base leading-snug">
                            {member.name}
                          </p>
                          <p class="flex flex-row gap-2 items-center text-sm lg:text-base text-primary-500">
                            <svg
                              width="10"
                              height="10"
                              viewBox="0 0 24 24"
                              fill="currentColor"
                            >
                              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                            </svg>
                            LinkedIn ↗
                          </p>
                        </div>
                      </a>
                    ))
                  }
                </div>
              </section>
              <section
                class="relative w-full flex flex-col gap-8 items-center max-w-ui py-16 md:py-20 lg:py-24 px-8 md:px-12 lg:px-16 z-10"
              >
                <div
                  id="cta-section-animation-sm"
                  class="absolute top-2/7 left-0 w-full h-3/7 xl:hidden overflow-hidden pointer-events-none"
                >
                  <div
                    id="cta-plane-sm-1"
                    class="absolute will-change-transform"
                  >
                    <svg
                      width="97"
                      height="55"
                      viewBox="0 0 193 110"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M136.537 54.7458L169.438 0L1.20723 54.7458L192.344 108.542L136.537 54.7458Z"
                        fill="#861336"></path>
                      <path
                        d="M192.344 108.542L138.334 54.7451H0.193497L192.344 108.542Z"
                        fill="#4D0519"></path>
                      <path
                        d="M166.958 64.9408L137.589 56.322L166.958 44.6611L166.958 64.9408Z"
                        fill="#4D0519"></path>
                    </svg>
                  </div>
                  <div
                    id="cta-plane-sm-2"
                    class="absolute will-change-transform overflow-hidden"
                  >
                    <svg
                      width="97"
                      height="55"
                      viewBox="0 0 193 110"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M136.537 54.7458L169.438 0L1.20723 54.7458L192.344 108.542L136.537 54.7458Z"
                        fill="#861336"></path>
                      <path
                        d="M192.344 108.542L138.334 54.7451H0.193497L192.344 108.542Z"
                        fill="#4D0519"></path>
                      <path
                        d="M166.958 64.9408L137.589 56.322L166.958 44.6611L166.958 64.9408Z"
                        fill="#4D0519"></path>
                    </svg>
                  </div>
                </div>
                <header
                  class="flex flex-col items-center gap-1 lg:gap-3 text-center max-w-3xl z-10"
                >
                  <span
                    class="text-primary-500 font-semibold text-xs md:text-sm lg:text-base xl:text-lg uppercase"
                  >
