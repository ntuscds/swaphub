---
import Posthog from "../components/posthog.astro";
import { SignInButton } from "../components/sign-in-button";
import "../styles/global.css";

const NAMES = [
  "Monkey",
  "ICC Lover",
  "CC is my passion",
  "Disgruntled Student",
  "Minmaxer3000",
  "Trillionaire",
  "Please hire me",
  "Sleep Deprived",
  "Procrastinator",
  "Exchange Kid",
  "CC Lover",
  "I really need a job",
  "Hire me",
  "Stop ghosting my apps",
  "GPA Gambler",
  "Covfefe",
];

const COURSES = [
  "ML4",
  "CC6",
  "CC7",
  "CC2",
  "CC3",
  "CC15",
  "ML0004",
  "CC0006",
  "CC0007",
  "CC0003",
  "CC0002",
  "CC0015",
  "SC3000",
  "SC2207",
  "SC1006",
  "MH1812",
  "SC1004",
  "AB1501",
  "AB1301",
  "DM3015",
  "MA4002",
];

const DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri"];

function randomInt(min: number, max: number) {
  return Math.floor(Math.random() * (max - min + 1)) + min;
}

function randomChoice<T>(arr: T[]): T {
  return arr[randomInt(0, arr.length - 1)];
}

function padIndex(n: number) {
  return String(n).padStart(5, "0");
}

function randomIndex() {
  return padIndex(randomInt(0, 99999));
}

function randomTimeSlot() {
  const startHour = randomInt(8, 18);
  const startMin = randomChoice([0, 20, 30, 50]);
  const durationHours = randomChoice([1, 1.5, 2]);
  const endTotalMin = startHour * 60 + startMin + durationHours * 60;
  const endHour = Math.min(21, Math.floor(endTotalMin / 60));
  const endMin = endTotalMin % 60;
  const start = `${String(startHour).padStart(2, "0")}.${String(startMin).padStart(2, "0")}`;
  const end = `${String(endHour).padStart(2, "0")}.${String(endMin).padStart(2, "0")}`;
  return `${start}-${end}`;
}

function generateMessageTemplate(): {
  title: string;
  lines: string[];
} {
  const course = randomChoice(COURSES);
  const haveIdx = randomIndex();
  const day = randomChoice(DAYS);
  const timeSlot = randomTimeSlot();

  const haveIdxNum = parseInt(haveIdx, 10);
  const wantSingle = Math.random() < 0.4;
  let wantStr: string;
  if (wantSingle) {
    let wantIdx = randomIndex();
    while (wantIdx === haveIdx) {
      wantIdx = randomIndex();
    }
    wantStr = `want: ${wantIdx}`;
  } else {
    let want1 = randomInt(0, 99999);
    let want2 = randomInt(0, 99999);
    while (want1 === haveIdxNum || want2 === haveIdxNum) {
      want1 = randomInt(0, 99999);
      want2 = randomInt(0, 99999);
    }
    if (want1 > want2) [want1, want2] = [want2, want1];
    if (want1 === want2) want2 = Math.min(99999, want1 + 1);
    wantStr = `want: ${padIndex(want1)}-${padIndex(want2)}`;
  }

  return {
    title: randomChoice(NAMES),
    lines: [
      `looking to swap ${course}`,
      `have: ${haveIdx} ${day} ${timeSlot}`,
      wantStr,
    ],
  };
}

const MESSAGE_TEMPLATES = Array.from({ length: 20 }, () =>
  generateMessageTemplate()
);

const LANE_COUNT = 3;
const CARDS_PER_LANE = 8;

const lanes = Array.from({ length: LANE_COUNT }, () =>
  Array.from({ length: CARDS_PER_LANE }, () => {
    const index = Math.floor(Math.random() * MESSAGE_TEMPLATES.length);
    return MESSAGE_TEMPLATES[index];
  })
);
